{
    "extends": "astro/tsconfigs/strict",
    "compilerOptions": {
        "noImplicitAny": true /* Enable error reporting for expressions and declarations with an implied 'any' type. */,
        "baseUrl": "./",
        "paths": {
            "@/*": ["./src/*"]
        },
        "ignoreDeprecations": "6.0"
    },
    "include": [".astro/types.d.ts", "**/*"],
    "exclude": ["dist"]
}
